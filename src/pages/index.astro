---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import SectionTitle from "@components/SectionTitle.astro";
import PublicationCard from "@components/PublicationCard.astro";
import { profile } from "@data/profile";
import { publications } from "@data/publications";

const recentPublications = [...publications]
  .sort((a, b) => b.year - a.year || Number(b.selected) - Number(a.selected) || a.title.localeCompare(b.title))
  .slice(0, 5);
const timelineItems = [
  ...profile.education.map((item) => ({ ...item, kind: "Education", title: item.degree, detail: item.supervisor ? `Supervisor: ${item.supervisor}` : "" })),
  ...profile.experience.map((item) => ({ ...item, kind: "Experience", title: item.role, detail: `Supervisor: ${item.supervisor}` }))
];
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
---

<BaseLayout>
  <Hero />

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionTitle eyebrow="About" title="Academic Bio" />
    <div class="grid gap-8 lg:grid-cols-[1.05fr_1fr] lg:gap-14">
      <p class="max-w-2xl text-lg leading-8 text-slate-600">
        {profile.bio[0]}
      </p>
      <div class="border-l-2 border-accent-100 pl-5 sm:pl-6">
        <h3 class="text-sm font-semibold text-slate-950">Research Interests</h3>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2 lg:grid-cols-1">
          {profile.researchInterests.map((interest) => (
            <li class="flex gap-3">
              <span class="mt-2.5 h-1.5 w-1.5 flex-none rounded-full bg-accent-600"></span>
              <span>{interest}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <SectionTitle eyebrow="Background" title="Experience" />
      <section class="border-y border-slate-200 bg-white">
        <ol>
          {timelineItems.map((item) => (
            <li class="grid gap-4 border-b border-slate-200 py-6 last:border-b-0 sm:grid-cols-[120px_48px_1fr] sm:items-start sm:gap-6">
              <p class="pt-1 text-sm font-semibold text-accent-700">{item.period}</p>
              <img src={withBase(item.logo)} alt={`${item.institution} logo`} class="h-12 w-12 rounded-full border border-slate-200 bg-white object-contain p-1.5" loading="lazy" />
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">{item.kind}</p>
                <h3 class="mt-1 text-base font-semibold text-slate-950">{item.institution}</h3>
                <p class="mt-1 text-sm leading-6 text-slate-700">{item.title}</p>
                {item.detail && <p class="mt-0.5 text-sm leading-6 text-slate-500">{item.detail}</p>}
              </div>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <SectionTitle eyebrow="Publications" title="Publications" />
        <a href={withBase("/publications")} class="mb-6 text-sm font-semibold text-accent-700 hover:text-accent-600">All publications</a>
      </div>
      <div class="border-y border-slate-200 bg-white px-1 sm:px-3">
        {recentPublications.map((publication) => <PublicationCard publication={publication} />)}
      </div>
    </div>
  </section>

</BaseLayout>
