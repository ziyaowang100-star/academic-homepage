---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import SectionTitle from "@components/SectionTitle.astro";
import PublicationCard from "@components/PublicationCard.astro";
import { profile } from "@data/profile";
import { publications } from "@data/publications";

const recentPublications = [...publications]
  .sort((a, b) => b.year - a.year || Number(b.selected) - Number(a.selected) || a.title.localeCompare(b.title))
  .slice(0, 5);
const timelineItems = [
  ...profile.education.map((item) => ({ ...item, kind: "Education", title: item.degree, detail: item.supervisor ? `Supervisor: ${item.supervisor}` : "" })),
  ...profile.experience.map((item) => ({ ...item, kind: "Experience", title: item.role, detail: `Supervisor: ${item.supervisor}` }))
];
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<BaseLayout>
  <Hero />

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionTitle eyebrow="About" title="Academic Bio" />
    <div class="max-w-5xl space-y-5 text-base leading-8 text-slate-600">
      <p>
        Devoted to distribution network planning and optimization with integration of cutting-edge theory and practice.
        Focuses on implementing state-of-the-art theories and technologies into real-world engineering scenarios. Active
        in interdisciplinary academic exchanges, core technical and scientific issues are summarized from engineering
        practices.
      </p>
      <p>
        <strong class="font-semibold text-slate-950"> Research interests:</strong> reliability and resilience assessment
        of distribution networks; digital planning of smart distribution networks; power grid planning under climate
        change; distribution network planning with high renewable energy penetration; AI/OR-assisted decision-making for
        power systems.
      </p>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <SectionTitle eyebrow="Background" title="Experience" />
      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
        <ol class="space-y-6">
          {timelineItems.map((item) => (
            <li class="grid gap-3 border-l-2 border-accent-100 pl-4 sm:grid-cols-[140px_1fr] sm:gap-6">
              <p class="text-sm font-medium text-accent-700">{item.period}</p>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">{item.kind}</p>
                <h3 class="mt-1 flex items-center gap-3 font-semibold text-slate-950">
                  <img src={withBase(item.logo)} alt={`${item.institution} logo`} class="h-9 w-9 rounded-full border border-slate-200 bg-white object-contain p-1" loading="lazy" />
                  <span>{item.institution}</span>
                </h3>
                <p class="mt-1 text-sm leading-6 text-slate-700">{item.title}</p>
                {item.detail && <p class="text-sm leading-6 text-slate-600">{item.detail}</p>}
              </div>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <SectionTitle eyebrow="Publications" title="Publications" />
        <a href={withBase("/publications")} class="mb-6 text-sm font-semibold text-accent-700 hover:text-accent-600">All publications</a>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white px-5 shadow-soft">
        {recentPublications.map((publication) => <PublicationCard publication={publication} />)}
      </div>
    </div>
  </section>

</BaseLayout>
