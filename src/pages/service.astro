---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionTitle from "@components/SectionTitle.astro";
import { academicCommunity, graduateThesisMentoring, journalReviewing } from "@data/service";
---

<BaseLayout
  title="Academic Service | Ziyao Wang"
  description="Academic service by Ziyao Wang, including journal reviewing, graduate research collaboration, thesis supervision, and academic community engagement."
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Service"
      title="Academic Service"
      description="Journal reviewing, graduate research collaboration, and academic activity."
    />

    <div class="divide-y divide-slate-200 border-y border-slate-200">
      <section class="grid gap-6 py-9 lg:grid-cols-[15rem_minmax(0,1fr)] lg:gap-12">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Journal Reviewing</h2>
        <div class="grid gap-8 md:grid-cols-2 md:gap-10">
          <div>
            <h3 class="text-sm font-semibold text-slate-950">International Journals</h3>
            <ul class="mt-3 divide-y divide-slate-200 border-y border-slate-200">
              {journalReviewing.international.map((journal) => (
                <li class="flex gap-3 py-3 text-sm leading-6 text-slate-700">
                  <span class="mt-2.5 h-1.5 w-1.5 flex-none rounded-full bg-accent-600"></span>
                  <span>{journal}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-950">Chinese-Language Journals</h3>
            <ul class="mt-3 divide-y divide-slate-200 border-y border-slate-200">
              {journalReviewing.chineseLanguage.map((journal) => (
                <li class="flex gap-3 py-3 text-sm leading-6 text-slate-700">
                  <span class="mt-2.5 h-1.5 w-1.5 flex-none rounded-full bg-accent-600"></span>
                  <span>{journal}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="grid gap-6 py-9 lg:grid-cols-[15rem_minmax(0,1fr)] lg:gap-12">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Graduate Research Collaboration</h2>
        <ol class="divide-y divide-slate-200 border-y border-slate-200">
          {graduateThesisMentoring.map((item) => (
            <li class="grid gap-2 py-4 sm:grid-cols-[11rem_minmax(0,1fr)] sm:gap-6">
              <p class="font-semibold text-slate-950">{item.student}</p>
              <p class="text-sm leading-7 text-slate-600"><cite class="not-italic">{item.thesis}</cite></p>
            </li>
          ))}
        </ol>
      </section>

      <section class="grid gap-6 py-9 lg:grid-cols-[15rem_minmax(0,1fr)] lg:gap-12">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Academic Activity</h2>
        <ul class="divide-y divide-slate-200 border-y border-slate-200">
          {academicCommunity.map((item) => (
            <li class="py-4 text-sm leading-7 text-slate-700">{item}</li>
          ))}
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
