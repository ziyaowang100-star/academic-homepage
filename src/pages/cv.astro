---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionTitle from "@components/SectionTitle.astro";
import { profile } from "@data/profile";

const timelineItems = [
  ...profile.education.map((item) => ({ ...item, kind: "Education", title: item.degree, detail: item.supervisor ? `Supervisor: ${item.supervisor}` : "" })),
  ...profile.experience.map((item) => ({ ...item, kind: "Experience", title: item.role, detail: `Supervisor: ${item.supervisor}` }))
];
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
---

<BaseLayout title="CV | Ziyao Wang" description="Academic CV of Ziyao Wang, Postdoctoral Researcher in Electrical Engineering at the University of Macau.">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <SectionTitle eyebrow="Curriculum Vitae" title="CV" description="Download the latest CV PDF or review selected academic background information below." />
      <a href={withBase("/cv.pdf")} class="mb-6 rounded bg-accent-700 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600">Download PDF</a>
    </div>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
      <h2 class="text-xl font-semibold text-slate-950">Experience</h2>
      <ol class="mt-5 space-y-6">
        {timelineItems.map((item) => (
          <li class="grid gap-3 border-l-2 border-accent-100 pl-4 sm:grid-cols-[140px_1fr] sm:gap-6">
            <p class="text-sm font-medium text-accent-700">{item.period}</p>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">{item.kind}</p>
              <h3 class="mt-1 flex items-center gap-3 font-semibold text-slate-950">
                <img src={withBase(item.logo)} alt={`${item.institution} logo`} class="h-9 w-9 rounded-full border border-slate-200 bg-white object-contain p-1" loading="lazy" />
                <span>{item.institution}</span>
              </h3>
              <p class="mt-1 text-sm leading-6 text-slate-700">{item.title}</p>
              {item.detail && <p class="text-sm leading-6 text-slate-600">{item.detail}</p>}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mt-8 rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
      <h2 class="text-xl font-semibold text-slate-950">Authorized Invention Patents</h2>
      <ol class="mt-5 space-y-5 text-sm leading-6 text-slate-600">
        {profile.patents.map((item, index) => (
          <li class="grid gap-3 border-b border-slate-200 pb-5 last:border-b-0 last:pb-0 sm:grid-cols-[3rem_1fr]">
            <span class="font-semibold tabular-nums text-accent-700">[{index + 1}]</span>
            <div>
              <p class="font-semibold text-slate-950">{item.title}</p>
              <p class="mt-1">Inventors: {item.inventors}</p>
              <p class="mt-1">Assignee: {item.assignee}</p>
              <p class="mt-1">
                {item.jurisdiction}, {item.status}. Application date: {item.applicationDate}; grant date: {item.grantDate}.
              </p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
        <h2 class="text-xl font-semibold text-slate-950">Book</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
          {profile.books.map((item) => (
            <li>
              {item.authors}. <span class="font-semibold text-slate-950">{item.title}</span>. {item.publisher}. {item.type}.
            </li>
          ))}
        </ul>
      </section>
      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
        <h2 class="text-xl font-semibold text-slate-950">Academic Service</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
          {profile.service.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
