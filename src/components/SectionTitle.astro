---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-6 max-w-3xl">
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-700">{eyebrow}</p>}
  <h2 class="text-2xl font-semibold tracking-tight text-slate-950 sm:text-3xl">{title}</h2>
  {description && <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>}
</div>
