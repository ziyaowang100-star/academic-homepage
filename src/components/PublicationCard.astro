---
import type { Publication } from "@data/publications";

interface Props {
  publication: Publication;
  label?: string;
}

const { publication, label } = Astro.props;

const markedAuthors = publication.authors.replace(
  /(Ziyao Wang\*?)/g,
  '<strong class="font-semibold text-slate-950">$1</strong>'
);

const hasPaperLink = publication.paperLink && publication.paperLink !== "#";
const hasDoiLink = publication.doi && publication.doi !== "#";
const showDoiLink = hasDoiLink && publication.doi !== publication.paperLink;
---

<article class="min-w-0 overflow-hidden border-b border-slate-200 bg-white py-5 last:border-b-0">
  <div class="grid min-w-0 gap-3 sm:grid-cols-[3.25rem_1fr]">
    {label && (
      <div class="text-sm font-semibold tabular-nums text-accent-700 sm:pt-0.5">
        [{label}]
      </div>
    )}
    <div class="min-w-0">
      <p class="break-words text-sm leading-7 text-slate-700 [overflow-wrap:anywhere]"><span set:html={markedAuthors}></span><span>. </span>{hasPaperLink ? (
        <a
          class="break-words font-semibold text-slate-950 underline decoration-accent-100 decoration-2 underline-offset-4 transition hover:text-accent-700 hover:decoration-accent-600 [overflow-wrap:anywhere]"
          href={publication.paperLink}
          target="_blank"
          rel="noreferrer"
        >
          {publication.title}
        </a>
      ) : (
        <span class="break-words font-semibold text-slate-950 [overflow-wrap:anywhere]">{publication.title}</span>
      )}<span>. </span><em>{publication.venue}</em><span>{publication.volume ? `, ${publication.volume}` : ""}{publication.pages ? `, ${publication.pages}` : ""}. {publication.year}.</span>{publication.type === "Chinese Journal" && <span> (in Chinese).</span>}</p>

      <div class="mt-3 flex max-w-full flex-wrap items-center gap-2">
        {publication.status === "Accepted" && (
          <span class="rounded border border-amber-200 bg-amber-50 px-2 py-1 text-xs font-medium text-amber-800">Accepted</span>
        )}
        {publication.selected && (
          <span class="rounded border border-accent-100 bg-accent-50 px-2 py-1 text-xs font-medium text-accent-700">Selected</span>
        )}
        {publication.tags.slice(0, 3).map((tag) => (
          <span class="max-w-full break-words rounded border border-slate-200 px-2 py-1 text-xs text-slate-600 [overflow-wrap:anywhere]">{tag}</span>
        ))}
        <span class="h-4 w-px bg-slate-200"></span>
        {hasPaperLink && (
          <a class="text-xs font-semibold text-accent-700 hover:text-accent-600" href={publication.paperLink} target="_blank" rel="noreferrer">
            Paper
          </a>
        )}
        {showDoiLink && (
          <a class="text-xs font-semibold text-accent-700 hover:text-accent-600" href={publication.doi} target="_blank" rel="noreferrer">
            DOI
          </a>
        )}
      </div>
    </div>
  </div>
</article>
