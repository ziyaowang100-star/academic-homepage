---
import type { Publication } from "@data/publications";

interface Props {
  publication: Publication;
  label?: string;
}

const { publication, label } = Astro.props;

const markedAuthors = publication.authors.replace(
  /(Ziyao Wang\*?)/g,
  '<strong class="font-semibold text-slate-950 underline decoration-2 underline-offset-2">$1</strong>'
);

const hasPaperLink = publication.paperLink && publication.paperLink !== "#";
const wrapperClass = label ? "grid min-w-0 gap-3 sm:grid-cols-[3.25rem_1fr]" : "min-w-0";
const isPatent = publication.type === "Patent";
const isBook = publication.type === "Book";
---

<article class="min-w-0 overflow-hidden border-b border-slate-200 bg-white py-5 last:border-b-0">
  <div class={wrapperClass}>
    {label && (
      <div class="text-sm font-semibold tabular-nums text-accent-700 sm:pt-0.5">
        [{label}]
      </div>
    )}
    <div class="min-w-0">
      <p class="break-words text-sm leading-7 text-slate-700 [overflow-wrap:anywhere]"><span set:html={markedAuthors}></span><span>. </span>{hasPaperLink ? (
        <a
          class="break-words font-semibold text-slate-950 underline decoration-accent-100 decoration-2 underline-offset-4 transition hover:text-accent-700 hover:decoration-accent-600 [overflow-wrap:anywhere]"
          href={publication.paperLink}
          target="_blank"
          rel="noreferrer"
        >
          {publication.title}
        </a>
      ) : (
        <span class="break-words font-semibold text-slate-950 [overflow-wrap:anywhere]">{publication.title}</span>
      )}<span>. </span><em>{publication.venue}</em><span>{publication.volume ? `, ${publication.volume}` : ""}{publication.pages ? `, ${publication.pages}` : ""}. {publication.year}.</span>{publication.type === "Chinese Journal" && <span> (in Chinese).</span>}{["Accepted", "Granted"].includes(publication.status) && <span> {publication.status}.</span>}</p>

      {isPatent && (
        <p class="mt-2 break-words text-sm leading-6 text-slate-600 [overflow-wrap:anywhere]">
          {publication.patentNumber && <span>Patent No.: {publication.patentNumber}. </span>}
          {publication.assignee && <span>Assignee: {publication.assignee}. </span>}
          {publication.applicationDate && <span>Application date: {publication.applicationDate}. </span>}
          {publication.grantDate && <span>Grant date: {publication.grantDate}.</span>}
        </p>
      )}

      {isBook && publication.isbn && (
        <p class="mt-2 text-sm leading-6 text-slate-600">ISBN: {publication.isbn}.</p>
      )}

    </div>
  </div>
</article>
