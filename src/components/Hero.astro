---
import { profile } from "@data/profile";

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;

const contactLinks = [
  {
    label: "Email",
    href: `mailto:${profile.email}`,
    icon: "email",
    color: "text-sky-600",
    iconBg: "bg-sky-50"
  },
  {
    label: "Google Scholar",
    href: profile.links.googleScholar,
    icon: "scholar",
    color: "text-blue-600",
    iconBg: "bg-blue-50"
  },
  {
    label: "GitHub",
    href: profile.links.github,
    icon: "github",
    color: "text-slate-800",
    iconBg: "bg-slate-100"
  },
  {
    label: "ORCID",
    href: profile.links.orcid,
    icon: "orcid",
    color: "text-[#a6ce39]",
    iconBg: "bg-lime-50"
  },
  {
    label: "LinkedIn",
    href: profile.links.linkedin,
    icon: "linkedin",
    color: "text-[#0a66c2]",
    iconBg: "bg-blue-50"
  }
].filter((link) => link.href && !link.href.startsWith("["));
---

<section class="border-b border-slate-200 bg-white">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-[1fr_260px] md:items-center lg:px-8 lg:py-20">
    <div>
      <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
        {profile.name}
      </h1>
      <div class="mt-6 flex flex-wrap gap-x-5 gap-y-3" aria-label="Contact links">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            title={link.label}
            aria-label={link.label}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noreferrer" : undefined}
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-600 transition hover:text-accent-700"
          >
            <span class:list={["inline-flex h-7 w-7 items-center justify-center rounded", link.iconBg, link.color]}>
              {link.icon === "email" && (
                <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                  <path d="m3 7 9 6 9-6"></path>
                </svg>
              )}
              {link.icon === "scholar" && (
                <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
                  <path d="M12 3 2 8.2l10 5.2 10-5.2L12 3Z"></path>
                  <path d="M6 11.5v4.2c1.6 1.7 3.6 2.6 6 2.6s4.4-.9 6-2.6v-4.2l-6 3.1-6-3.1Z"></path>
                </svg>
              )}
              {link.icon === "github" && (
                <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.2a9.8 9.8 0 0 0-3.1 19.1c.5.1.7-.2.7-.5v-1.9c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.6 1 1.6 1 .9 1.5 2.3 1.1 2.9.8.1-.7.4-1.1.7-1.3-2.2-.3-4.6-1.1-4.6-4.9 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.6 0 0 .9-.3 2.8 1a9.6 9.6 0 0 1 5.1 0c2-1.3 2.8-1 2.8-1 .5 1.3.2 2.3.1 2.6.7.7 1 1.6 1 2.7 0 3.8-2.3 4.7-4.6 4.9.4.3.8 1 .8 2v2.6c0 .3.2.6.7.5A9.8 9.8 0 0 0 12 2.2Z"></path>
                </svg>
              )}
              {link.icon === "orcid" && (
                <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.2A9.8 9.8 0 1 0 12 21.8 9.8 9.8 0 0 0 12 2.2Zm-3.1 5.3a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Zm1 10.1H7.8v-6.7h2.1v6.7Zm3.2 0h-2.1V7.6h2.1v10Zm2.5 0h-1.7V7.6h1.8c3 0 4.8 2 4.8 5s-1.8 5-4.9 5Zm.1-8.1h-.7v6.2h.6c1.8 0 2.7-1.1 2.7-3.1 0-2-.9-3.1-2.6-3.1Z"></path>
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor" aria-hidden="true">
                  <path d="M5 3.8A2.2 2.2 0 1 0 5 8.2 2.2 2.2 0 0 0 5 3.8ZM3.2 9.8h3.6V20H3.2V9.8ZM9 9.8h3.4v1.4h.1c.5-.9 1.7-1.7 3.4-1.7 3.6 0 4.3 2.4 4.3 5.5v5H16.6v-4.4c0-1.1 0-2.5-1.5-2.5s-1.8 1.2-1.8 2.4V20H9V9.8Z"></path>
                </svg>
              )}
            </span>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href={withBase("/cv")} class="rounded bg-accent-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-accent-600">Download CV</a>
      </div>
    </div>
    <div class="mx-auto w-full max-w-[260px]">
      <img class="aspect-[4/5] w-full rounded-lg border border-slate-200 object-cover shadow-soft" src={withBase(profile.image)} alt={profile.imageAlt} width="520" height="650" />
    </div>
  </div>
</section>
