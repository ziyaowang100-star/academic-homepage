---
import SectionTitle from "@components/SectionTitle.astro";

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
---

<section id="research" class="scroll-mt-20 border-t border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Research"
      title="Research Highlights"
      description="Digital planning technologies and software systems for smart distribution networks."
    />

    <article class="space-y-5">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-accent-700">Digital Planning Platform</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">From Grid Data to Planning Decisions</h2>
      </div>
      <img
        src={withBase("/images/research/digital-planning-platform-core.png")}
        alt="Digital planning workflow for smart distribution networks"
        class="w-full rounded-lg border border-slate-200 bg-white shadow-soft"
        width="1705"
        height="660"
        loading="lazy"
      />
      <ul class="grid gap-3 text-sm leading-6 text-slate-600 sm:text-base md:grid-cols-3">
        <li class="border-l-2 border-accent-100 pl-4">
          Integrates wiring diagram recognition, spatial load forecasting, GIS/CIM data, and engineering databases into
          a unified digital planning workflow.
        </li>
        <li class="border-l-2 border-accent-100 pl-4">
          Supports PDN intelligent analysis modules including power flow, security analysis, reliability analysis, AC/DC
          planning, and flexible distribution network planning.
        </li>
        <li class="border-l-2 border-accent-100 pl-4">
          Connects automated planning scheme recommendation with human-in-the-loop expert review for practical
          distribution network planning.
        </li>
      </ul>
    </article>
  </div>
</section>

<section class="border-y border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <article class="space-y-5">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-accent-700">Software Applications</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Demonstration Applications in CSG and SGCC</h2>
      </div>
      <img
        src={withBase("/images/research/software-application-outcomes-core.png")}
        alt="Software system applications for power distribution system planning"
        class="w-full rounded-lg border border-slate-200 bg-white shadow-soft"
        width="1780"
        height="840"
        loading="lazy"
      />
      <div class="grid gap-6 text-sm leading-7 text-slate-600 sm:text-base lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <p>
          The software systems provide CIM file-based component modeling, automatic modeling based on CSG-GIS, wiring
          diagram recognition, and interactive planning analysis for real distribution network projects.
        </p>
        <p>
          These systems have supported AC/DC hybrid PDS planning, low-carbon-oriented PDS planning, and
          CPS-coordinated PDS planning, and have been widely applied in demonstration projects across China Southern
          Power Grid and State Grid Corporation of China.
        </p>
      </div>
    </article>
  </div>
</section>
