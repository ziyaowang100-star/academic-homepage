---
import { profile } from "@data/profile";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/publications", label: "Publications" },
  { href: "/cv", label: "CV" },
  { href: "/contact", label: "Contact" }
];

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
const currentPath = Astro.url.pathname
  .replace(new RegExp(`^${base.replace(/\/$/, "")}`), "")
  .replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-4 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8" aria-label="Main navigation">
    <a href={withBase("/")} class="group inline-flex items-center gap-3" aria-label={`${profile.name} homepage`}>
      <span class="flex h-10 w-10 items-center justify-center rounded border border-accent-100 bg-accent-50 text-sm font-semibold text-accent-700">ZW</span>
      <span>
        <span class="block text-base font-semibold text-slate-950">{profile.name}</span>
        <span class="block text-xs text-slate-500">{profile.title}</span>
      </span>
    </a>
    <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-slate-600">
      {navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, "") || "/";
        const active = currentPath === itemPath;
        return (
          <li>
            <a
              href={withBase(item.href)}
              class:list={[
                "transition hover:text-accent-700",
                active ? "text-accent-700" : "text-slate-600"
              ]}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
